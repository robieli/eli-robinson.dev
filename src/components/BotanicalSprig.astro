---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

{/* Vintage-botanical line drawing: a single sprig with alternating leaves */}
<svg
  viewBox="0 0 120 170"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  class={className}
  aria-hidden="true"
>
  <!-- main stem -->
  <path d="M60 165 C 58 130, 64 95, 60 60 C 58 40, 61 22, 60 8" />
  <!-- leaves, alternating left/right, each with a midrib -->
  <path d="M60 140 C 42 136, 30 124, 28 108 C 44 110, 56 122, 60 140 Z" />
  <path d="M60 140 C 50 130, 42 120, 36 112" stroke-width="1" />
  <path d="M61 118 C 79 112, 90 98, 91 82 C 75 86, 64 100, 61 118 Z" />
  <path d="M61 118 C 71 107, 79 96, 85 88" stroke-width="1" />
  <path d="M60 96 C 43 91, 32 79, 31 64 C 46 67, 57 79, 60 96 Z" />
  <path d="M60 96 C 51 86, 43 77, 37 69" stroke-width="1" />
  <path d="M60 72 C 76 66, 86 53, 87 39 C 72 43, 62 56, 60 72 Z" />
  <path d="M60 72 C 69 62, 76 53, 82 45" stroke-width="1" />
  <path d="M60 50 C 47 45, 39 36, 38 24 C 50 27, 58 37, 60 50 Z" />
  <path d="M60 50 C 53 42, 47 35, 42 28" stroke-width="1" />
  <!-- terminal bud -->
  <path d="M60 8 C 55 14, 55 20, 60 26 C 65 20, 65 14, 60 8 Z" />
</svg>
