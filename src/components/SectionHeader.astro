---
interface Props {
  number: string;
  title: string;
}

const { number, title } = Astro.props;
---

<header class="mb-10 md:mb-14">
  <p class="kicker text-leaf">
    <span>No. {number}</span>
  </p>
  <h2 class="font-display-soft mt-3 text-4xl font-semibold tracking-tight text-ink md:text-5xl">
    {title}
  </h2>
  <div class="rule-double mt-6"></div>
</header>
