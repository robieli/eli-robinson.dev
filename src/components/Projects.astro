---
import { projects, contactLinks } from "../data/site";
import SectionHeader from "./SectionHeader.astro";

const githubUrl = contactLinks.find((link) => link.label === "GitHub")?.href;
const repositoriesUrl = githubUrl ? `${githubUrl}?tab=repositories` : undefined;
---

<section id="projects" class="mx-auto max-w-4xl px-5 py-16 md:px-8 md:py-24">
  <SectionHeader number="02" title="Catalogue of Projects" />

  {
    /* set like a table of contents: numbered entries divided by hairline rules */
  }
  <ol class="divide-y divide-rule border-b border-rule">
    {
      projects.map((project, i) => {
        const Entry = project.href ? "a" : "div";
        return (
          <li>
            <Entry
              href={project.href}
              class="group grid grid-cols-[3rem_1fr] gap-x-4 gap-y-2 py-8 md:grid-cols-[4rem_1fr_10rem] md:gap-x-8"
            >
              <span class="font-display-soft text-2xl text-moss transition-colors duration-200 group-hover:text-leaf md:text-3xl">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div>
                <h3 class="font-display-soft text-2xl font-semibold text-ink transition-colors duration-200 group-hover:text-leaf md:text-3xl">
                  {project.title}
                </h3>
                <p class="mt-2 max-w-prose leading-relaxed text-ink-soft">
                  {project.description}
                </p>
              </div>
              <p class="kicker col-start-2 self-start text-sm text-ink-soft md:col-start-3 md:pt-2 md:text-right">
                {project.tags.join(" · ")}
              </p>
            </Entry>
          </li>
        );
      })
    }
  </ol>

  {
    repositoriesUrl && (
      <div class="mt-14 flex justify-center">
        <a
          href={repositoriesUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="kicker border border-ink px-8 py-3 text-sm text-ink transition-colors duration-200 hover:border-leaf hover:bg-leaf hover:text-paper"
        >
          See All
        </a>
      </div>
    )
  }
</section>
