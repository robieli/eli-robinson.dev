---
import { contactLinks, site } from "../data/site";
import BotanicalSprig from "./BotanicalSprig.astro";

const year = new Date().getFullYear();
---

<!-- Inverted dark endcap. In dark mode the global ink/paper tokens swap, which would
     turn this into a near-white panel; pin them locally so the footer stays a dark
     surface (a hair lifted from the page bg) with cream text in both themes. -->
<footer
  id="contact"
  class="bg-ink text-paper dark:[--color-ink:#211e1a] dark:[--color-paper:#ece7d9]"
>
  <div class="mx-auto max-w-4xl px-5 py-16 md:px-8 md:py-20">
    <div class="flex flex-col items-center gap-10 text-center">
      <BotanicalSprig class="h-16 w-auto text-moss" />

      <p class="font-display-soft text-3xl text-balance italic md:text-4xl">
        Let’s correspond.
      </p>

      <ul class="flex flex-wrap items-baseline justify-center gap-x-8 gap-y-3">
        {
          contactLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="kicker text-sm text-paper/80 underline decoration-moss/60 underline-offset-4 transition-colors duration-200 hover:text-moss"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="w-full border-t border-paper/15 pt-8">
        <p class="text-sm text-paper/60">
          © {year}
          {site.name}
        </p>
      </div>
    </div>
  </div>
</footer>
